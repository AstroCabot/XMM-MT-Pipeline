# Refactored XMM-Newton comet pipeline configuration
#
# Copy this file, edit the required paths, and then run:
#   ./xmm_comet_pipeline.sh my_config.env all

# -----------------------------------------------------------------------------
# Required paths
# -----------------------------------------------------------------------------
WORKDIR=/path/to/output
ODFDIR=/path/to/odf

# Short /tmp/ symlink name (avoids CFITSIO path-length limits on WSL/OneDrive).
# A deterministic name means .env files and SUM.SAS paths survive across runs.
# Leave empty to fall back to a PID-based name (changes every run).
# Set SHORTLINK_KEEP=yes to leave the symlink alive after the pipeline exits.
SHORTLINK_NAME=
SHORTLINK_KEEP=no

# -----------------------------------------------------------------------------
# Moving-target ephemeris
# Supply either TARGET_ID (+ TARGET_ID_TYPE) or TRACK_INPUT.
# -----------------------------------------------------------------------------
TARGET_ID=""
TARGET_ID_TYPE=smallbody
TRACK_INPUT=

# Optional manual reference point for the comet frame.
COMET_REF_RA=
COMET_REF_DEC=

TRACK_STEP=30s
MAX_SEG_BLUR_ARCSEC=1.0
SEGMENT_SNAP_S=0.0
MIN_SEG_S=0.0

# -----------------------------------------------------------------------------
# Clean event filtering
# espfilt rangescale: multiplier on Gaussian sigma for the rate threshold.
#   Higher values keep more mildly-flared intervals (more data, higher bkg).
#   Previous pipeline defaults were PN=15, MOS=6.  These relaxed values retain
#   more exposure for background-subtracted extended-source work.
# espfilt allowsigma: width limit for the quiescent-peak Gaussian fit.
# -----------------------------------------------------------------------------
CLEAN_PI_MIN=200
CLEAN_PI_MAX=12000
ESPFILT_RANGESCALE_PN=25.0
ESPFILT_RANGESCALE_MOS=20.0
ESPFILT_ALLOWSIGMA=3.0
# Set to yes to skip espfilt flare filtering entirely (retains all exposure time).
CLEAN_SKIP_ESPFILT=no

# -----------------------------------------------------------------------------
# Still-sky detection
# The SAS detect stage still uses SRCDET_PI_*.
# DETECT_QC_BANDS controls the diagnostic mosaics written for QC.
# -----------------------------------------------------------------------------
SRCDET_PI_MIN=1000
SRCDET_PI_MAX=12000
DETECT_MIN_ML=10.0
DETECT_EXCLUDE_TRACK_ARCSEC=30.0
DETECT_DS9_RADIUS_ARCSEC=20.0
DETECT_QC_BANDS="soft:200:1000;hard:1000:12000"
DETECT_QC_BIN_ARCSEC=6.0
DETECT_QC_PAD_ARCMIN=2.0

# -----------------------------------------------------------------------------
# Attitude reconstruction
# -----------------------------------------------------------------------------
AHF_INPUT=
PREMERGE_IMAGE_SIZE_DEG=1.5
ATTMOVE_GRANULARITY=5
ATTMOVE_MINSTABLE=30
ATTCALC_IMAGE_SIZE_DEG=0.6

# -----------------------------------------------------------------------------
# Source/background apertures in the comet frame (arcsec)
# -----------------------------------------------------------------------------
SRC_DX_ARCSEC=0.0
SRC_DY_ARCSEC=0.0
SRC_R_ARCSEC=60.0

BKG_MODE=annulus
BKG_DX_ARCSEC=0.0
BKG_DY_ARCSEC=0.0
BKG_R_ARCSEC=150.0
BKG_RIN_ARCSEC=90.0
BKG_ROUT_ARCSEC=150.0

FIELD_SOURCE_MASK_R_ARCSEC=20.0
IMAGE_MASK_RADIUS_ARCSEC=20.0

# Contamination sampling and selected science policy.
# full   = keep all time bins, rely on spatial mask
# src    = cut only source-aperture overlaps
# bkg    = cut only background-aperture overlaps
# strict = cut either overlap type
CONTAM_SAMPLE_STEP_S=5.0
CONTAM_MIN_GOOD_SPAN_S=0.0
SCIENCE_GTI_POLICY=full
SCIENCE_APPLY_TRAIL_MASK=yes

# -----------------------------------------------------------------------------
# Imaging
# -----------------------------------------------------------------------------
IMAGE_BANDS="soft:200:1000;broad:300:2000;hard:1000:12000"
IMAGE_RADIUS_ARCSEC=900.0
IMAGE_BIN_ARCSEC=2.0
EEXPMAP_ATTREBIN=0.020626481

# -----------------------------------------------------------------------------
# Light curves
# Relative-only correction is the safer default for a diffuse target.
# -----------------------------------------------------------------------------
LC_PI_MIN=300
LC_PI_MAX=2000
LC_BIN_S=500.0
LC_DETXBINS=5
LC_DETYBINS=5
LC_APPLY_ABSOLUTE_CORRECTIONS=no
LC_ALLOW_NOABS_FALLBACK=yes

# -----------------------------------------------------------------------------
# QC
# -----------------------------------------------------------------------------
QC_COMPARE_HORIZONS=no
QC_SPOTCHECK_BAND=

# -----------------------------------------------------------------------------
# Spectra
# -----------------------------------------------------------------------------
SPEC_PI_MIN=300
SPEC_PI_MAX=5000
SPEC_DETXBINS=5
SPEC_DETYBINS=5
SPEC_MIN_SAFE_DETBINS=15
SPEC_USE_ODF_ATT=yes
SPECGROUP_MINCOUNTS=25
SPECGROUP_OVERSAMPLE=3.0
